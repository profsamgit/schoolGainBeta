rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Regras Gerais: Somente usuários autenticados podem interagir com o sistema básico
    function isAuthenticated() {
      return request.auth != null;
    }

    // Verifica se o usuário logado é um Administrador (Admin ou Super Admin)
    function isAdmin() {
      // Permite se o usuário estiver autenticado via Firebase Auth (Super Admins)
      // Nota: Para permitir que Gestores (Admins comuns) gravem no banco,
      // eles também precisarão ser registrados no Firebase Authentication.
      return isAuthenticated();
    }

    // Regras por Coleção
    
    match /users/{userId} {
      allow read: if isAuthenticated();
      // Permite escrita apenas se for o próprio usuário (ex: trocar senha) ou um Admin
      allow write: if isAdmin() || (isAuthenticated() && request.auth.token.email == userId);
    }

    match /students/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || (isAuthenticated() && request.auth.token.email == userId);
    }

    match /admins/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || (isAuthenticated() && request.auth.token.email == userId);
    }

    match /staff/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || (isAuthenticated() && request.auth.token.email == userId);
    }

    match /super_admins/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || (isAuthenticated() && request.auth.token.email == userId);
    }

    match /visitors/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || (isAuthenticated() && request.auth.token.email == userId);
    }

    match /userStates/{userId} {
      allow read: if isAuthenticated();
      // Apenas o próprio usuário (via ações de jogo) ou Admin podem alterar o estado
      allow write: if isAdmin() || (isAuthenticated() && request.auth.token.email == userId);
    }

    match /schools/{schoolId} {
      allow read: if true; // Informações da escola são públicas para o cadastro
      allow write: if isAdmin(); // Apenas Admins podem gerenciar escolas
    }

    match /terminals/{terminalId} {
      allow read: if true; // Terminais precisam ser lidos para autorização
      allow write: if isAdmin();
    }

    match /wasteEntries/{entryId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin(); // Apenas totens/admins registram coletas
    }

    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /rewards/{rewardId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /articles/{articleId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /participants/{participantId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /resetHistory/{resetId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /turmas/{turmaId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /cursos/{cursoId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /cargos/{cargoId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /setores/{setorId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
